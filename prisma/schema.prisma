generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-TENANT CORE
// ============================================================================

model Client {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  
  // RepSpark API Credentials
  devClientKey        String?
  devEnvironmentKey   String?
  uatClientKey        String?
  uatEnvironmentKey   String?
  prodClientKey       String?
  prodEnvironmentKey  String?
  
  // SFTP Credentials (shared across environments)
  sftpHost            String?
  sftpPort            Int       @default(22)
  sftpUsername        String?
  sftpPassword        String?
  sftpBasePath        String?
  
  // Sync Configuration
  syncEnabled         Boolean   @default(true)
  defaultEnvironment  String    @default("dev")
  
  // Relationships
  members             ClientMember[]
  options             Option[]
  sizeScales          SizeScale[]
  products            Product[]
  inventory           Inventory[]
  customers           Customer[]
  syncLogs            SyncLog[]
  images              ProductImage[]
  syncSchedule        SyncSchedule?
  licensedConfigurations LicensedConfiguration[]
  demoOrders          DemoOrder[]
  demoInvoices        DemoInvoice[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model ClientMember {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String   // Clerk user ID
  role      String   @default("member") // owner, admin, member
  
  createdAt DateTime @default(now())
  
  @@unique([clientId, userId])
  @@index([userId])
}

// ============================================================================
// FOUNDATION LAYER
// ============================================================================

model Option {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  elementType  String
  keyCode      String
  stringValue  String
  stringValue2 String?
  numericValue Float?
  booleanValue Boolean?
  dateValue    DateTime?
  enabled      Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([clientId, elementType, keyCode])
  @@index([clientId])
  @@index([clientId, elementType])
}

model SizeScale {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  code         String
  description  String
  brandCode    String   @default("CC")
  divisionCode String?
  enabled      Boolean  @default(true)
  
  sizes        Size[]
  products     Product[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([clientId, code])
  @@index([clientId])
}

model Size {
  id            String    @id @default(cuid())
  sizeScaleId   String
  sizeScale     SizeScale @relation(fields: [sizeScaleId], references: [id], onDelete: Cascade)
  
  code          String
  description   String
  index         Int
  sizeTypes     String?   // JSON for multi-dimensional sizing
  enabled       Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([sizeScaleId, code])
  @@index([sizeScaleId])
}

// ============================================================================
// BUSINESS LAYER
// ============================================================================

model Product {
  id                   String     @id @default(cuid())
  clientId             String
  client               Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  productNumber        String
  wholesalePrice       Float
  
  productName          String?
  longDescription      String?
  shortDescription     String?
  retailPrice          Float      @default(0)
  discountedPrice      Float      @default(0)
  standardCost         Float      @default(0)
  
  // Flexible options stored as JSON
  options              String?
  
  // For products generated from a parent product's option explosion
  parentProductId      String?
  parentProduct        Product?   @relation("ProductVariants", fields: [parentProductId], references: [id], onDelete: SetNull)
  colorVariants        Product[]  @relation("ProductVariants")
  
  categoryCode         String?
  colorCode            String?
  genderCode           String?
  seasonCode           String?
  divisionCode         String?
  
  sizeScaleId          String?
  sizeScale            SizeScale? @relation(fields: [sizeScaleId], references: [id])
  
  brandCode            String     @default("CC")
  catalogCode          String?
  dimensionCode        String?
  marketingSeasonCode  String?
  styleGroupCode       String?
  
  productType          Int        @default(2)
  enabled              Boolean    @default(true)
  ignoreDiscounts      Boolean    @default(false)
  associationsPerGroup Int        @default(0)
  weight               Float      @default(0)
  
  imageUrl             String?
  
  // Decoration metadata (for Type 3 Insignia / Type 4 Licensed logos)
  league               String?
  teamCode             String?
  teamName             String?
  teamDescription      String?
  
  // Insignia settings (for Type 2 base products)
  insigniaEnabled      Boolean    @default(false)
  allowedPlacements    String?    // JSON array of placement codes
  finishPlacementRules String?    // JSON array of {finish, placement} pairs
  insigniaColorOptions String?    // JSON array of color option codes
  
  // Customer restrictions (for Type 3/4 logos)
  customerRestrictions String?    // JSON array of customer codes, null = all
  
  inventory            Inventory[]
  images               ProductImage[]
  demoOrderLines       DemoOrderLine[]
  
  // Licensed configuration relations
  licensedConfigs      LicensedConfiguration[] @relation("ProductLicensedConfigs")
  decorationConfigs    LicensedConfiguration[] @relation("DecorationLicensedConfigs")
  
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  
  @@unique([clientId, productNumber])
  @@index([clientId])
  @@index([clientId, seasonCode])
  @@index([clientId, categoryCode])
  @@index([clientId, productType])
  @@index([sizeScaleId])
  @@index([parentProductId])
}

model ProductImage {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  
  filename      String
  sftpPath      String
  publicUrl     String
  mimeType      String
  size          Int
  
  uploadedAt    DateTime @default(now())
  
  @@index([clientId])
  @@index([productId])
}

model Inventory {
  id                    String   @id @default(cuid())
  clientId              String
  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  productId             String
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  productNumber         String
  sizeCode              String
  colorCode             String?
  genderCode            String?
  seasonCode            String?
  divisionCode          String?
  brandCode             String   @default("CC")
  dimensionCode         String?
  productCategoryCode   String?
  locationCode          String?
  
  availableDate         DateTime
  availableQuantity     Int
  replenishmentQuantity Int      @default(0)
  infiniteAvailability  Boolean  @default(false)
  committedQuantity     Int      @default(0)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([clientId, productId, sizeCode, availableDate])
  @@index([clientId])
  @@index([productId])
  @@index([clientId, productNumber])
}

model Customer {
  id                   String   @id @default(cuid())
  clientId             String
  client               Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  customerCode         String
  name                 String
  isBillTo             Boolean  @default(true)
  enabled              Boolean  @default(true)
  storeCode            String?
  
  // Self-referential: Bill-To has stores, Store belongs to Bill-To
  parentId             String?
  parent               Customer?  @relation("CustomerStores", fields: [parentId], references: [id], onDelete: Cascade)
  stores               Customer[] @relation("CustomerStores")
  
  address1             String?
  address2             String?
  city                 String?
  state                String?
  zip                  String?
  country              String   @default("US")
  
  phoneNumber          String?
  faxNumber            String?
  
  salesPersonCode      String?
  brandCode            String?
  divisionCode         String?
  termsCode            String?
  shippingMethodCode   String?
  
  discountPercentage   Float    @default(0)
  pricePlanCode        String?
  customerGroupCode    String?
  classificationCode   String?
  channelCode          String?
  typeCode             String?
  buyingGroupCode      String?
  creditStatusCode     String?
  commissionPercentage Float    @default(0)
  
  dba                  String?
  paymentsVisibility   String?
  referenceNumber      String?
  
  billingOrders        DemoOrder[] @relation("BillingOrders")
  shippingOrders       DemoOrder[] @relation("ShippingOrders")
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  @@unique([clientId, customerCode, storeCode])
  @@index([clientId])
  @@index([clientId, customerCode])
  @@index([clientId, salesPersonCode])
  @@index([parentId])
}

// ============================================================================
// LICENSED CONFIGURATIONS (ProductGroups)
// ============================================================================

model LicensedConfiguration {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Base product (Type 2)
  productId       String
  product         Product  @relation("ProductLicensedConfigs", fields: [productId], references: [id], onDelete: Cascade)
  
  // Decoration/Logo product (Type 4)
  decorationId    String
  decoration      Product  @relation("DecorationLicensedConfigs", fields: [decorationId], references: [id], onDelete: Cascade)
  
  placement       String
  colorChoice     String
  
  // Finished good display (from PRD)
  finishedGoodName      String?
  finishedGoodImageUrl  String?
  finishedGoodShortDesc String?
  finishedGoodLongDesc  String?
  
  // Pricing overrides
  wholesalePrice  Float?
  retailPrice     Float?
  
  dateRangeBegin  DateTime?
  dateRangeEnd    DateTime?
  enabled         Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([clientId, productId, decorationId, placement, colorChoice])
  @@index([clientId])
  @@index([productId])
  @@index([decorationId])
}

// ============================================================================
// DEMO DATA GENERATION
// ============================================================================

model DemoOrder {
  id                   String    @id @default(cuid())
  clientId             String
  client               Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  orderNumber          String
  orderDate            DateTime
  entryDate            DateTime
  
  billingCustomerId    String
  billingCustomer      Customer  @relation("BillingOrders", fields: [billingCustomerId], references: [id], onDelete: Cascade)
  
  shippingCustomerId   String?
  shippingCustomer     Customer? @relation("ShippingOrders", fields: [shippingCustomerId], references: [id])
  
  purchaseOrder        String?
  statusCode           String    // OPEN, SHIPPED, INVOICED
  
  shippingMethodCode   String?
  shippingCarrierName  String?
  trackingNumber       String?
  
  lines                DemoOrderLine[]
  invoice              DemoInvoice?
  
  createdAt            DateTime  @default(now())
  
  @@unique([clientId, orderNumber])
  @@index([clientId])
  @@index([billingCustomerId])
  @@index([shippingCustomerId])
}

model DemoOrderLine {
  id                  String    @id @default(cuid())
  orderId             String
  order               DemoOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  lineNumber          Int
  productId           String
  product             Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  productNumber       String
  productName         String?
  colorCode           String?
  colorDescription    String?
  genderCode          String?
  genderDescription   String?
  seasonCode          String?
  seasonDescription   String?
  categoryCode        String?
  categoryDescription String?
  sizeScaleCode       String?
  divisionCode        String?
  divisionDescription String?
  brandCode           String    @default("CC")
  
  sizeCode            String
  orderedQuantity     Int
  invoicedQuantity    Int       @default(0)
  
  retailPrice         Float
  wholesalePrice      Float
  sellPrice           Float
  cost                Float
  
  statusCode          String
  
  @@index([orderId])
  @@index([productId])
}

model DemoInvoice {
  id                 String    @id @default(cuid())
  clientId           String
  client             Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  invoiceNumber      String
  orderId            String    @unique
  order              DemoOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  invoiceCreatedDate DateTime
  invoiceSentDate    DateTime?
  invoiceDueDate     DateTime
  
  invoiceAmount      Float
  freightAmount      Float     @default(0)
  taxAmount          Float     @default(0)
  
  createdAt          DateTime  @default(now())
  
  @@unique([clientId, invoiceNumber])
  @@index([clientId])
  @@index([orderId])
}

// ============================================================================
// SYNC MANAGEMENT
// ============================================================================

model SyncLog {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  entityType   String
  environment  String
  syncMode     String
  status       String
  recordCount  Int
  errorMessage String?
  errorDetails String?
  
  triggeredBy  String
  
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  
  @@index([clientId])
  @@index([clientId, entityType])
  @@index([clientId, status])
}

model SyncSchedule {
  id               String    @id @default(cuid())
  clientId         String    @unique
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Cron expressions (e.g., "0 6 * * *" = daily at 6am UTC)
  optionsCron      String?
  sizingCron       String?
  productsCron     String?
  inventoryCron    String?
  customersCron    String?
  imagesCron       String?
  fullSyncCron     String?
  
  // Last successful sync timestamps
  lastSyncOptions   DateTime?
  lastSyncSizing    DateTime?
  lastSyncProducts  DateTime?
  lastSyncInventory DateTime?
  lastSyncCustomers DateTime?
  lastSyncImages    DateTime?
  lastFullSync      DateTime?
  
  environment      String    @default("dev")
  enabled          Boolean   @default(false)
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
